; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GAME-JAMM-TPLM"
config/description="Arcade satu layar: kendarai mobil menyeberangi jalan sambil dikejar ayam penipu."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameConfig="*res://autoload/game_config.gd"
GameState="*res://autoload/game_state.gd"

[display]

window/size/viewport_width=864
window/size/viewport_height=336
window/size/window_width_override=1296
window/size/window_height_override=504
window/stretch/mode="canvas_items"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
